066760,"user":{"displayName":"hadi halim","userId":"13915541843408654107"},"user_tz":-420},"id":"ZqW1UEH_UejQ","colab":{"base_uri":"https://localhost:8080/"},"outputId":"3f5bd092-f54d-428f-bd86-21437104636e"},"outputs":[{"output_type":"stream","name":"stdout","text":["Menggunakan device: cuda\n"]}],"source":["BATCH_SIZE = 32\n","EPOCHS = 10\n","LEARNING_RATE = 0.0001\n","DEVICE = torch.device(\"cuda\" if torch.cuda.is_available() else \"cpu\")\n","print(f\"Menggunakan device: {DEVICE}\")"]},{"cell_type":"markdown","metadata":{"id":"zzXvkoKADYOR"},"source":["####**4. Buat Fungsi untuk Transform dan Pilih Dataset**"]},{"cell_type":"code","execution_count":5,"metadata":{"executionInfo":{"elapsed":941,"status":"ok","timestamp":1773499067702,"user":{"displayName":"hadi halim","userId":"13915541843408654107"},"user_tz":-420},"id":"7jGaHQvOVK8V"},"outputs":[],"source":["class CustomCelebA(Dataset):\n","    def __init__(self, img_dir, label_file, transform=None):\n","        self.img_dir = img_dir\n","        self.transform = transform\n","        self.data = []\n","\n","        valid_images = set(os.listdir(img_dir))\n","\n","        with open(label_file, 'r') as f:\n","            lines = f.readlines()\n","            for line in lines[1:]:\n","                parts = line.strip().split()\n","                if len(parts) > 21:\n","                    img_name = parts[0]\n","                    if img_name in valid_images:\n","                        label = 1 if parts[21] == '1' else 0\n","                        self.data.append((img_name, label))\n","\n","    def __len__(self):\n","        return len(self.data)\n","\n","    def __getitem__(self, idx):\n","        img_name, label = self.data[idx]\n","        img_path = os.path.join(self.img_dir, img_name)\n","        image = Image.open(img_path).convert('RGB')\n","        if self.transform:\n","            image = self.transform(image)\n","        return image, label\n","\n","transform = transforms.Compose([\n","    transforms.Resize((224, 224)),\n","    transforms.ToTensor(),\n","    transforms.Normalize(mean=[0.485, 0.456, 0.406], std=[0.229, 0.224, 0.225])\n","])\n","\n","full_dataset = CustomCelebA(img_dir=IMG_DIR, label_file=LABEL_FILE, transform=transform)"]},{"cell_type":"markdown","metadata":{"id":"FEJzizhcD5vn"},"source":["####**5. Split Data**"]},{"cell_type":"code","execution_count":6,"metadata":{"executionInfo":{"elapsed":6,"status":"ok","timestamp":1773499067712,"user":{"displayName":"hadi halim","userId":"13915541843408654107"},"user_tz":-420},"id":"Q6zE9FLXYSJe","colab":{"base_uri":"https://localhost:8080/"},"outputId":"eb2c573f-1819-4790-c3c1-e494794c0239"},"outputs":[{"output_type":"stream","name":"stdout","text":["Total Dataset: 5000\n","Total Data Train: 4000 | Total Data Val: 500 | Total Data Test: 500\n"]}],"source":["print(f\"Total Dataset: {len(full_dataset)}\")\n","train_size = int(0.8 * len(full_dataset))\n","val_size = int(0.1 * len(full_dataset))\n","test_size = len(full_dataset) - train_size - val_size\n","\n","train_dataset, val_dataset, test_dataset = random_split(full_dataset, [train_size, val_size, test_size])\n","\n","train_loader = DataLoader(train_dataset, batch_size=BATCH_SIZE, shuffle=True)\n","val_loader = DataLoader(val_dataset, batch_size=BATCH_SIZE, shuffle=False)\n","test_loader = DataLoader(test_dataset, batch_size=BATCH_SIZE, shuffle=False)\n","\n","print(f\"Total Data Train: {len(train_dataset)} | Total Data Val: {len(val_dataset)} | Total Data Test: {len(test_dataset)}\")"]},{"cell_type":"markdown","metadata":{"id":"DeAPMi8cEKD6"},"source":["####**6. Visualisasi Sample Gambar**"]},{"cell_type":"code","execution_count":17,"metadata":{"executionInfo":{"elapsed":3460,"status":"ok","timestamp":1773500675975,"user":{"displayName":"hadi halim","userId":"13915541843408654107"},"user_tz":-420},"id":"RhJJTOYRESKW","colab":{"base_uri":"https://localhost:8080/","height":375},"outputId":"0fdee02d-1f43-4148-a0c0-8b532a9aa158"},"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 1500x500 with 5 Axes>"],"image/png":"\n"},"metadata":{}}],"source":["def showImage(inp, title=None):\n","    inp = inp.numpy().transpose((1, 2, 0))\n","    mean = np.array([0.485, 0.456, 0.406])\n","    std = np.array([0.229, 0.224, 0.225])\n","    inp = std * inp + mean\n","    inp = np.clip(inp, 0, 1)\n","    plt.imshow(inp)\n","    if title is not None:\n","        plt.title(title)\n","\n","inputs, classes = next(iter(train_loader))\n","fig = plt.figure(figsize=(15, 5))\n","for i in range(5):\n","    ax = fig.add_subplot(1, 5, i+1, xticks=[], yticks=[])\n","    showImage(inputs[i])\n","    if (classes[i].item() == 0):\n","      ax.set_title(f\"Label: Female\")\n","    else:\n","      ax.set_title(f\"Label: Male\")\n","plt.suptitle(\"Sample Gambar dari Dataset\")\n","plt.show()"]},{"cell_type":"markdown","metadata":{"id":"s2fCfBvIFQq9"},"source":["####**7. Inisiasi Model ResNet**"]},{"cell_type":"code","execution_count":13,"metadata":{"executionInfo":{"elapsed":357,"status":"ok","timestamp":1773499858642,"user":{"displayName":"hadi halim","userId":"13915541843408654107"},"user_tz":-420},"id":"YM3sO0jqYZXA","colab":{"base_uri":"https://localhost:8080/"},"outputId":"36aa7985-910f-4208-d270-0b614d7dbba1"},"outputs":[{"output_type":"stream","name":"stdout","text":["Downloading: \"https://download.pytorch.org/models/resnet18-f37072fd.pth\" to /root/.cache/torch/hub/checkpoints/resnet18-f37072fd.pth\n"]},{"output_type":"stream","name":"stderr","text":["100%|██████████| 44.7M/44.7M [00:00<00:00, 140MB/s]\n"]}],"source":["model = models.resnet18(weights=models.ResNet18_Weights.DEFAULT)\n","num_features = model.fc.in_features\n","model.fc = nn.Linear(num_features, 2)\n","\n","model = model.to(DEVICE)\n","\n","criterion = nn.CrossEntropyLoss()\n","optimizer = optim.Adam(model.parameters(), lr=LEARNING_RATE)"]},{"cell_type":"markdown","metadata":{"id":"3-bNkWdQF1hP"},"source":["####**8. Proses Training**"]},{"cell_type":"code","execution_count":15,"metadata":{"id":"tmvCAOIiYjQ2","executionInfo":{"status":"ok","timestamp":1773500104816,"user_tz":-420,"elapsed":220847,"user":{"displayName":"hadi halim","userId":"13915541843408654107"}},"colab":{"base_uri":"https://localhost:8080/"},"outputId":"45d357ab-bdb1-4468-d472-ae3efb22a5de"},"outputs":[{"output_type":"stream","name":"stdout","text":["\n","Training ResNet...\n","Epoch [1/10] | Train Loss: 0.0862 | Train Acc: 96.70% | Val Loss: 0.1967 | Val Acc: 92.80%\n","Epoch [2/10] | Train Loss: 0.0269 | Train Acc: 99.25% | Val Loss: 0.1176 | Val Acc: 95.00%\n","Epoch [3/10] | Train Loss: 0.0089 | Train Acc: 99.70% | Val Loss: 0.1217 | Val Acc: 95.00%\n","Epoch [4/10] | Train Loss: 0.0069 | Train Acc: 99.80% | Val Loss: 0.1293 | Val Acc: 95.60%\n","Epoch [5/10] | Train Loss: 0.0040 | Train Acc: 99.95% | Val Loss: 0.2131 | Val Acc: 94.60%\n","Epoch [6/10] | Train Loss: 0.0053 | Train Acc: 99.85% | Val Loss: 0.1249 | Val Acc: 95.80%\n","Epoch [7/10] | Train Loss: 0.0057 | Train Acc: 99.88% | Val Loss: 0.8145 | Val Acc: 84.80%\n","Epoch [8/10] | Train Loss: 0.0209 | Train Acc: 99.15% | Val Loss: 0.1352 | Val Acc: 96.20%\n","Epoch [9/10] | Train Loss: 0.0156 | Train Acc: 99.28% | Val Loss: 0.1736 | Val Acc: 94.80%\n","Epoch [10/10] | Train Loss: 0.0084 | Train Acc: 99.72% | Val Loss: 0.1559 | Val Acc: 95.60%\n"]}],"source":["train_losses, val_losses = [], []\n","train_accuracies, val_accuracies = [], []\n","\n","print(\"\\nTraining ResNet...\")\n","for epoch in range(EPOCHS):\n","    model.train()\n","    running_train_loss, correct_train, total_train = 0.0, 0, 0\n","\n","    for inputs, labels in train_loader:\n","        inputs, labels = inputs.to(DEVICE), labels.to(DEVICE)\n","\n","        optimizer.zero_grad()\n","        outputs = model(inputs)\n","        loss = criterion(outputs, labels)\n","        loss.backward()\n","        optimizer.step()\n","\n","        running_train_loss += loss.item()\n","        _, predicted = torch.max(outputs.data, 1)\n","        total_train += labels.size(0)\n","        correct_train += (predicted == labels).sum().item()\n","\n","    avg_train_loss = running_train_loss / len(train_loader)\n","    train_acc = 100 * correct_train / total_train\n","    train_losses.append(avg_train_loss)\n","    train_accuracies.append(train_acc)\n","\n","    model.eval()\n","    running_val_loss, correct_val, total_val = 0.0, 0, 0\n","    with torch.no_grad():\n","        for inputs, labels in val_loader:\n","            inputs, labels = inputs.to(DEVICE), labels.to(DEVICE)\n","            outputs = model(inputs)\n","            loss = criterion(outputs, labels)\n","\n","            running_val_loss += loss.item()\n","            _, predicted = torch.max(outputs.data, 1)\n","            total_val += labels.size(0)\n","            correct_val += (predicted == labels).sum().item()\n","\n","    avg_val_loss = running_val_loss / len(val_loader)\n","    val_acc = 100 * correct_val / total_val\n","    val_losses.append(avg_val_loss)\n","    val_accuracies.append(val_acc)\n","\n","    print(f\"Epoch [{epoch+1}/{EPOCHS}] | Train Loss: {avg_train_loss:.4f} | Train Acc: {train_acc:.2f}% | Val Loss: {avg_val_loss:.4f} | Val Acc: {val_acc:.2f}%\")"]},{"cell_type":"markdown","metadata":{"id":"O9OEOCTvGM4C"},"source":["####**9. Visualisasi Proses Training**"]},{"cell_type":"code","execution_count":10,"metadata":{"executionInfo":{"elapsed":822,"status":"ok","timestamp":1773499776545,"user":{"displayName":"hadi halim","userId":"13915541843408654107"},"user_tz":-420},"id":"DrBTfNvjY1D6","colab":{"base_uri":"https://localhost:8080/","height":430},"outputId":"8dac6a19-6535-40f6-9305-f6775044758e"},"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 1400x500 with 2 Axes>"],"image/png":"\n"},"metadata":{}}],"source":["plt.figure(figsize=(14, 5))\n","\n","plt.subplot(1, 2, 1)\n","plt.plot(range(1, EPOCHS+1), train_losses, marker='o', label='Train Loss')\n","plt.plot(range(1, EPOCHS+1)